{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "AWS_REGION",
    "AWS_PROFILE",
    "DATABASE_URL",
    "CLOUDWATCH_ENABLED",
    "CLOUDWATCH_LOG_GROUP",
    "CLOUDWATCH_LOG_LEVEL",
    "CLOUDWATCH_LOG_STREAM",
    "LOG_LEVEL",
    "NODE_ENV",
    "PORT",
    "SERVICE_NAME",
    "VITE_SENTRY_DSN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
