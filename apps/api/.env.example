# Local API configuration. Copy this file to .env to enable the values locally.
PORT=8000
NODE_ENV=development
SERVICE_NAME=flowforge-api
DATABASE_URL=postgres://flowforge:flowforge@localhost:5432/flowforge

# Use `verbose` once to see every diagnostic log level. Use `info` normally.
LOG_LEVEL=verbose

# CloudWatch Logs is opt-in. Leave this false for console-only local development.
CLOUDWATCH_ENABLED=false
CLOUDWATCH_LOG_LEVEL=verbose
AWS_REGION=eu-central-1
# Name of the existing profile from `aws configure list-profiles`.
# AWS credentials remain in ~/.aws/credentials or your SSO session, never here.
# AWS_PROFILE=flowforge-development
CLOUDWATCH_LOG_GROUP=/flowforge/api/development
CLOUDWATCH_LOG_STREAM=local-api
